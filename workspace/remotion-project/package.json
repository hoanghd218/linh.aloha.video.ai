{
  "name": "mkt-bds-remotion-template",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion 9:16 broker-creator video template (avatar + 14 overlay variants + zoom hooks + SFX + captions). Pre-built — driven by overlays.json per workspace.",
  "scripts": {
    "start": "remotion studio",
    "studio": "remotion studio",
    "build": "remotion render Root out.mp4",
    "render": "remotion render Root",
    "render-draft": "remotion render Root renders/draft.mp4 --crf 28 --concurrency 2",
    "render-final": "remotion render Root renders/final.mp4 --crf 18"
  },
  "dependencies": {
    "@remotion/cli": "4.0.380",
    "@remotion/google-fonts": "^4.0.462",
    "@remotion/media-utils": "4.0.380",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.380"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "typescript": "5.6.3"
  }
}
